<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="ring" android:thickness="6dp" android:useLevel="false">
            <solid android:color="#33FFFFFF" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="270" android:toDegrees="270" android:pivotX="50%" android:pivotY="50%">
            <shape android:shape="ring" android:thickness="6dp" android:useLevel="true">
                <gradient android:startColor="#FF4081" android:endColor="#7C4DFF" android:type="sweep" />
                <corners android:radius="6dp"/>
            </shape>
        </rotate>
    </item>
</layer-list>