<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Настройки"
        android:textColor="@color/text_white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Тема приложения"
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_theme_purple"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Фиолетовая тема"
        android:backgroundTint="@color/purple"
        android:textColor="@color/white"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_theme_turquoise"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Бирюзовая тема"
        android:backgroundTint="@color/turquoise"
        android:textColor="@color/white"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_theme_orange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Оранжевая тема"
        android:backgroundTint="@color/neon_orange"
        android:textColor="@color/white"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_theme_green"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Зеленая тема"
        android:backgroundTint="@color/matrix_green"
        android:textColor="@color/white"
        android:layout_marginBottom="24dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_gray"
        android:alpha="0.3"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Виброотдача"
            android:textColor="@color/text_white"
            android:textSize="18sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_vibration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Легкая вибрация при нажатии на кнопки и изменении громкости"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Названия устройств"
            android:textColor="@color/text_white"
            android:textSize="18sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_device_names"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Показывать конкретные названия (Ryzen 5 5600G) вместо CPU/GPU"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

</LinearLayout>